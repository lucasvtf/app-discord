# Token do bot (Discord Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=

# Application ID (Developer Portal -> General Information -> Application ID)
CLIENT_ID=

# ID do servidor onde o bot opera
GUILD_ID=

# Canal onde o relatorio semanal sera postado
REPORT_CHANNEL_ID=

# Timezone do agendamento e dos cortes de periodo
TIMEZONE=America/Sao_Paulo

# Cron do relatorio semanal (default: sexta 18:00)
REPORT_CRON=0 18 * * 5
